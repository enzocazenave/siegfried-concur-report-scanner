// Prisma schema for the report scanner.
// Two tables: Scan + User. Every scan belongs to the user who pressed Escanear.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (pgBouncer) — la usa la app en runtime serverless.
  url       = env("DATABASE_URL")
  // Conexión directa — la usan `prisma db push` / `migrate`, que no van por el pooler.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  // Puede haber varios maestros. El primero se bootstrapea desde env vars si
  // la tabla está vacía; después, cualquier maestro puede crear operadores o
  // nuevos maestros. Solo los maestros gestionan usuarios.
  isMaster     Boolean  @default(false)
  createdAt    DateTime @default(now())

  scans Scan[]
}

model Scan {
  id           Int      @id @default(autoincrement())
  scanDate     DateTime @default(now())
  reportName   String
  employeeName String?
  employeeId   String
  // Equipo del empleado, copiado del padrón al momento de escanear (igual que
  // employeeName). Nullable por filas históricas previas al padrón.
  team         String?
  // Timestamp del envío. NULL = todavía no enviado. Lo estampa el botón
  // "Enviar" del historial (POST /api/scans/send) sobre los informes pendientes.
  sentAt       DateTime?
  createdAt    DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@index([scanDate])
  @@index([employeeId])
  @@index([reportName])
  @@index([userId])
  @@index([team])
  // Usado por el filtro de pendientes / stats (informes sin enviar).
  @@index([sentAt])
  // Used by the duplicate-check on POST /api/scans.
  @@index([reportName, employeeId])
}

// Padrón de empleados (ABM). Fuente de verdad para validar, al escanear, que
// el identificador leído por Claude corresponde a un empleado real.
model Employee {
  id           Int      @id @default(autoincrement())
  // Código Concur: "99000" + 5 dígitos (10 en total). Único.
  employeeId   String   @unique
  employeeName String
  team         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeName])
  @@index([team])
}

// Rate limiting: track login attempts per IP. Failed attempts inside the
// window block further attempts; successful login wipes the IP's failures.
model LoginAttempt {
  id          Int      @id @default(autoincrement())
  ipAddress   String
  success     Boolean
  attemptedAt DateTime @default(now())

  @@index([ipAddress, attemptedAt])
}

// Rate limiting / quotas: every call to /api/scan inserts a row here BEFORE
// touching the Claude API. Both per-minute burst and per-day quota read this.
model ScanAttempt {
  id          Int      @id @default(autoincrement())
  userId      Int
  attemptedAt DateTime @default(now())

  @@index([userId, attemptedAt])
}
