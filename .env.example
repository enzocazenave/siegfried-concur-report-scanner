# Postgres.
#  - DATABASE_URL          → conexión POOLED (pgBouncer). La usa la app.
#  - DATABASE_URL_UNPOOLED → conexión DIRECTA. La usa `prisma db push`/`migrate`.
#
# Local (docker compose up -d): ambas apuntan al mismo Postgres local.
# En Vercel: si conectás Neon desde Storage, estas dos variables se inyectan solas.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/report_scanner?schema=public"
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/report_scanner?schema=public"

# Anthropic API key — pediselo a sistemas (https://console.anthropic.com)
ANTHROPIC_API_KEY="sk-ant-..."

# Opcional: modelo a usar. Default: claude-haiku-4-5 (barato y rápido).
# Alternativas más precisas si hace falta: claude-sonnet-4-6, claude-opus-4-7.
# ANTHROPIC_MODEL="claude-haiku-4-5"

# Auth — secreto para cifrar las cookies de sesión. Generá uno con:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Debe tener ≥ 32 caracteres.
SESSION_PASSWORD="cambiame-por-un-secreto-largo-de-al-menos-32-caracteres-XXXXXXXX"

# Bootstrap del usuario maestro (solo se aplica si la tabla User está vacía).
# Después de correr `npm run db:seed`, cambiá la contraseña entrando con el master.
INITIAL_MASTER_USERNAME="admin"
INITIAL_MASTER_PASSWORD="cambiame-en-cuanto-entres"
